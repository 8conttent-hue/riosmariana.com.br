---
// About-B: Full-width com stats em destaque
interface Stat { value: string; label: string; }
interface Props {
  title: string;
  desc: string;
  image: string;
  btnText: string;
  btnLink: string;
  stats: Stat[];
}
const { title, desc, image, btnText, btnLink, stats } = Astro.props;
---
<section class="py-20 bg-gradient-to-b from-dark to-accent text-white overflow-hidden">
  <div class="max-w-6xl mx-auto px-4">
    <div class="grid md:grid-cols-2 gap-16 items-center mb-16">
      <!-- Imagem esquerda -->
      {image && (
        <div class="relative rounded-3xl overflow-hidden aspect-[4/3]">
          <img src={image} alt={title} class="w-full h-full object-cover opacity-80" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-dark/60 to-transparent"></div>
        </div>
      )}

      <!-- Texto direita -->
      <div>
        <span class="text-xs font-bold uppercase tracking-widest text-primary/80 mb-4 block">Quem somos</span>
        <h2 class="text-3xl md:text-5xl font-black leading-tight mb-6">{title}</h2>
        <p class="text-white/70 text-lg leading-relaxed mb-8">{desc}</p>
        <a
          href={btnLink}
          class="inline-flex items-center gap-2 px-7 py-3.5 bg-primary text-white font-bold rounded-xl hover:opacity-90 transition-opacity shadow-lg shadow-primary/30"
        >
          {btnText}
        </a>
      </div>
    </div>

    <!-- Stats row -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-px bg-white/10 rounded-2xl overflow-hidden">
      {[...stats, { value: '✓', label: '100% Gratuito' }].slice(0, 4).map((stat, i) => (
        <div class="bg-white/5 backdrop-blur p-8 text-center hover:bg-white/10 transition-colors">
          <div class="text-3xl font-black text-white mb-2">{stat.value}</div>
          <div class="text-sm text-white/60 uppercase tracking-widest">{stat.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>