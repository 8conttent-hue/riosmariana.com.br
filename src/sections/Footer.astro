---
// Footer-G: Floating Card Footer - Design moderno que flutua na página
import siteConfig from '../data/siteConfig.json';
const { name, menu = [] } = siteConfig as any;
const year = new Date().getFullYear();
---
<div class="px-4 pb-8 pt-20 bg-gray-50">
  <footer class="max-w-6xl mx-auto bg-dark text-white rounded-[2.5rem] shadow-[0_20px_60px_-15px_rgba(0,0,0,0.3)] overflow-hidden">
    <div class="px-8 lg:px-16 py-16">
      <div class="flex flex-col lg:flex-row items-center justify-between gap-12 text-center lg:text-left">
        
        <!-- Brand -->
        <div class="max-w-xs">
          <a href="/" class="text-3xl font-black tracking-tighter uppercase mb-6 block hover:text-primary transition-colors">
            {name}
          </a>
          <p class="text-white/40 text-sm leading-relaxed font-medium">
            Redefinindo o futuro do cuidado através da ciência de dados e empatia.
          </p>
        </div>

        <!-- Horizontal Nav Grid -->
        <div class="flex-1 flex flex-wrap items-center justify-center lg:justify-end gap-x-12 gap-y-6">
           {menu.map((item: any) => (
             <a href={item.href} class="text-sm font-black uppercase tracking-widest text-white/50 hover:text-white transition-colors">{item.label}</a>
           ))}
           <a href="/blog" class="px-8 py-3.5 bg-primary text-white font-black rounded-2xl hover:scale-105 transition-all text-xs uppercase tracking-widest">Ver Blog</a>
        </div>
      </div>

      <!-- Divider -->
      <div class="h-px w-full bg-white/5 my-12"></div>

      <!-- Bottom Meta -->
      <div class="flex flex-col md:flex-row items-center justify-between gap-6">
         <div class="text-[10px] font-bold text-white/20 uppercase tracking-[0.3em]">
            © {year} {name} • TODOS OS DIREITOS RESERVADOS
         </div>
         <div class="flex items-center gap-6">
            <span class="text-[9px] font-black text-white/30 uppercase tracking-widest">Apoio e Qualidade</span>
         </div>
      </div>
    </div>
  </footer>
</div>