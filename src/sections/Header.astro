---
// Header-J: Gradient Accent - Design limpo com borda inferior em gradiente
import siteConfig from '../data/siteConfig.json';
import { getAllPosts } from '../lib/posts';

const { name, menu: baseMenu = [] } = siteConfig;

// Buscar categorias REAIS do banco de dados (SSR)
const allPosts = await getAllPosts();
const realCategories = [...new Set(allPosts.map(p => p.category))].filter(Boolean);

// Injetar categorias reais no item "Blog" do menu
const menu = baseMenu.map((item: any) => {
  if (item.label.toLowerCase() === 'blog' || item.href === '/blog') {
    return {
      ...item,
      children: realCategories.length
        ? realCategories.map(cat => ({
            label: cat,
            href: `/categoria/${cat.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/[^a-z0-9\s-]/g, '').trim().replace(/\s+/g, '-')}`
          }))
        : undefined,
    };
  }
  return item;
});
---
<header class="bg-white relative z-[100]">
  <div class="max-w-6xl mx-auto px-4">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-1 group">
        <span class="text-3xl font-black text-transparent bg-clip-text bg-gradient-to-r from-primary to-accent italic tracking-tighter group-hover:from-accent group-hover:to-primary transition-all duration-500">
          {name}
        </span>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden md:flex items-center gap-1 px-1 py-1 rounded-2xl bg-gray-50/50 border border-gray-100 shadow-sm">
        {menu.map((item: any) => (
        item.children?.length ? (
          <div class="relative group flex items-center">
            <button type="button" class="px-5 py-2 text-xs font-bold text-gray-400 group-hover:text-dark group-hover:bg-white rounded-xl transition-all border border-transparent group-hover:border-gray-100 group-hover:shadow-sm flex items-center gap-1 cursor-pointer">
              {item.label}
              <svg class="w-3 h-3 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </button>
            <div class="absolute top-full left-0 z-[110] pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all">
              <div class="w-48 bg-white border border-gray-100 shadow-2xl rounded-2xl py-3">
                <a href={item.href} class="block px-6 py-1.5 text-[9px] font-black text-primary uppercase tracking-widest mb-1 border-b border-gray-50 pb-2 italic">Explorar</a>
                {item.children.map((child: any) => (
                  <a href={child.href} class="block px-6 py-2.5 text-[11px] font-bold text-gray-500 hover:text-primary hover:bg-gray-50 transition-colors uppercase italic tracking-tighter">
                    {child.label}
                  </a>
                ))}
              </div>
            </div>
          </div>
        ) : (
            <a
              href={item.href}
              class="px-5 py-2 text-xs font-bold text-gray-400 hover:text-dark hover:bg-white rounded-xl transition-all border border-transparent hover:border-gray-100 hover:shadow-sm"
            >
              {item.label}
            </a>
          )
        ))}
        <div class="w-px h-4 bg-gray-200 mx-2"></div>
        <a
          href="/blog"
          class="px-5 py-2 text-xs font-black text-primary hover:text-accent transition-colors"
        >
          BLOG
        </a>
      </nav>

      <!-- Actions/Mobile Toggle -->
      <div class="flex items-center gap-4">
        <a href="/contato" class="hidden lg:inline-block text-[10px] font-black uppercase tracking-widest text-dark border-b-2 border-primary hover:border-accent transition-all">Começar Agora</a>
        
        <button id="menu-btn-j" class="md:hidden p-3 rounded-2xl bg-primary/5 text-primary hover:bg-primary/10" aria-label="Menu">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M3 12h18M3 6h18M3 18h18"/></svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Animated Gradient Border -->
  <div class="absolute bottom-0 left-0 right-0 h-[3px] bg-gradient-to-r from-primary via-accent to-primary bg-[length:200%_auto] animate-gradient"></div>

  <!-- Mobile Menu -->
  <div id="mobile-menu-j" class="hidden md:hidden absolute top-full left-0 right-0 bg-white border-b border-gray-100 shadow-2xl z-50 p-6 space-y-4">
    <div class="grid grid-cols-2 gap-4">
      {menu.map((item: any) => (
        <div class="space-y-2">
          <a href={item.href} class="block p-4 rounded-xl bg-gray-50 text-sm font-bold text-gray-700 hover:bg-primary/5 hover:text-primary border border-gray-100">{item.label}</a>
          {item.children?.length ? (
            <div class="pl-3 space-y-2 border-l-2 border-primary/20">
              {item.children.map((child: any) => (
                <a href={child.href} class="block text-xs font-bold text-gray-600 hover:text-primary py-1">{child.label}</a>
              ))}
            </div>
          ) : null}
        </div>
      ))}
    </div>
    <a href="/blog" class="block w-full py-4 rounded-xl bg-dark text-white text-center font-bold">Acessar Blog</a>
  </div>
</header>

<style>
  @keyframes gradient {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }
  .animate-gradient {
    animation: gradient 3s ease infinite;
  }
</style>

<script>
  document.getElementById('menu-btn-j')?.addEventListener('click', () => {
    document.getElementById('mobile-menu-j')?.classList.toggle('hidden');
  });
</script>